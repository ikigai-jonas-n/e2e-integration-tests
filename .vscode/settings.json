{
  "yaml.schemas": {
    "https://raw.githubusercontent.com/compose-spec/compose-spec/master/schema/compose-spec.json": [
      "docker-compose*.yml",
      "docker-compose*.yaml"
    ]
  },
  "files.watcherExclude": {
    "**/.e2e-worktrees/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true
  },
  "search.exclude": {
    "**/.e2e-worktrees/**": true
  },
  "js/ts.preferences.autoImportFileExcludePatterns": [
    ".e2e-worktrees"
  ]
}
