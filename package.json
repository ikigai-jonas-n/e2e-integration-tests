{
  "name": "e2e-integration-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "./run-e2e.sh",
    "test:raw": "bun test --timeout 600000",
    "test:fast": "bun test --timeout ${E2E_FAST_TIMEOUT_MS:-1000}",
    "setup:env": "bun run scripts/dev-services.ts",
    "reset": "bash scripts/reset.sh",
    "lint": "bun run type:check && bun run prettier:check && bun run lint:code",
    "lint:fix": "bun run prettier:fix && bun run lint:code --fix",
    "type:check": "tsc --noEmit",
    "lint:code": "eslint \"./**/*.{js,ts}\" --quiet",
    "prettier:check": "prettier --check \"**/*.{ts,js}\"",
    "prettier:fix": "prettier --write \"**/*.{ts,js}\"",
    "precommit": "bun run lint:fix && bun run test:raw"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ikigaians/migrate": "2.0.1-alpha.9",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "axios": "^1.16.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
